-- ==========================================
-- GAS STATION AUTOFARM
-- ==========================================

local GasStationRunning = false
local GasStationConnection = nil

local function StopGasStation()
    GasStationRunning = false
    if GasStationConnection then
        GasStationConnection:Disconnect()
        GasStationConnection = nil
    end
end

local function GasStationLoop()
    while GasStationRunning do
        local success, err = pcall(function()
            -- Disable door collisions
            for _, obj in ipairs(Workspace:GetDescendants()) do
                if obj:IsA('BasePart') and obj.Name:lower():find('door') then
                    obj.CanQuery = false
                end
            end
            
            local character = LocalPlayer.Character
            if not character then return end
            
            local humanoid = character:FindFirstChild('Humanoid')
            local hrp = character:FindFirstChild('HumanoidRootPart')
            if not humanoid or not hrp then return end
            
            -- Get job locations
            local gasTile = Workspace:FindFirstChild('Map') and Workspace.Map:FindFirstChild('Tiles') and Workspace.Map.Tiles:FindFirstChild('GasStationTile')
            if not gasTile then return end
            
            local quick11 = gasTile:FindFirstChild('Quick11')
            if not quick11 then return end
            
            local interior = quick11:FindFirstChild('Interior')
            if not interior then return end
            
            local jobFolder = interior:FindFirstChild('ShelfStockingJob')
            if not jobFolder then return end
            
            local box = jobFolder:FindFirstChild('NormalBox')
            local shelves = jobFolder:FindFirstChild('Shelves')
            
            if not box or not shelves then return end
            
            local prompt = box:FindFirstChildOfClass('ProximityPrompt')
            
            -- Movement Mode: Tween (Fast) or Humanoid (Pathfinder)
            local moveMode = ObsidianLib.Options.MovementMode and ObsidianLib.Options.MovementMode.Value or 'Tween (Fast)'
            
            if moveMode == 'Tween (Fast)' then
                -- Fast tween movement
                local function TweenToPosition(targetPos)
                    local distance = (hrp.Position - targetPos).Magnitude
                    local tweenInfo = TweenInfo.new(distance / 50, Enum.EasingStyle.Linear)
                    local tween = TweenService:Create(hrp, tweenInfo, {CFrame = CFrame.new(targetPos)})
                    tween:Play()
                    tween.Completed:Wait()
                end
                
                -- Go to box
                TweenToPosition(Vector3.new(149.924, 255.467, 208.347))
                task.wait(0.3)
                
                -- Grab box
                if prompt then
                    fireproximityprompt(prompt)
                end
                task.wait(0.5)
                
                -- Go to shelves
                TweenToPosition(Vector3.new(130.808, 255.467, 203.295))
                task.wait(0.5)
                
            else
                -- Humanoid pathfinding
                local path = PathfindingService:CreatePath({
                    AgentHeight = 5,
                    AgentRadius = 2,
                    AgentCanJump = true
                })
                
                -- Path to box
                path:ComputeAsync(hrp.Position, Vector3.new(149.924, 255.467, 208.347))
                path:MoveTo(humanoid)
                humanoid.MoveToFinished:Wait()
                task.wait(0.3)
                
                -- Grab box
                if prompt then
                    fireproximityprompt(prompt)
                end
                task.wait(0.5)
                
                -- Path to shelves
                path:ComputeAsync(hrp.Position, Vector3.new(130.808, 255.467, 203.295))
                path:MoveTo(humanoid)
                humanoid.MoveToFinished:Wait()
                task.wait(0.5)
            end
            
            -- Stock shelves logic
            for _, shelf in ipairs(shelves:GetChildren()) do
                if not GasStationRunning then break end
                for _, attachment in ipairs(shelf:GetChildren()) do
                    if attachment:IsA('Attachment') then
                        -- Check distance and interact
                        local dist = (attachment.WorldPosition - hrp.Position).Magnitude
                        if dist < 10 then
                            -- Shelf stocking interaction would go here
                            task.wait(0.1)
                        end
                    end
                end
            end
        end)
        
        if not success then
            warn('Gas Station Error:', err)
        end
        
        task.wait(0.5)
    end
end

GasGroup:AddLabel('⚠️ Take the Job before starting!')

GasGroup:AddToggle('GasStationToggle', {
    Text = 'Enable Gas Station Autofarm',
    Default = false,
    Callback = function(Value)
        if Value then
            GasStationRunning = true
            GasStationConnection = RunService.Heartbeat:Connect(function()
                if not GasStationRunning then return end
                -- Loop handled in spawn
            end)
            task.spawn(GasStationLoop)
        else
            StopGasStation()
        end
    end
})

-- ==========================================
-- BURGER KING AUTOFARM
-- ==========================================

local BurgerKingRunning = false
local BurgerKingConnection = nil

local function StopBurgerKing()
    BurgerKingRunning = false
    if BurgerKingConnection then
        BurgerKingConnection:Disconnect()
        BurgerKingConnection = nil
    end
end

local function BurgerKingLoop()
    while BurgerKingRunning do
        local success, err = pcall(function()
            local character = LocalPlayer.Character
            if not character then return end
            
            local humanoid = character:FindFirstChild('Humanoid')
            local hrp = character:FindFirstChild('HumanoidRootPart')
            if not humanoid or not hrp then return end
            
            -- Find Burger King tile
            local burgerTile = Workspace:FindFirstChild('Map') and Workspace.Map:FindFirstChild('Tiles') and Workspace.Map.Tiles:FindFirstChild('BurgerPlaceTile')
            if not burgerTile then return end
            
            -- Scan for job-related objects
            for _, obj in ipairs(burgerTile:GetDescendants()) do
                if not BurgerKingRunning then break end
                
                if obj:IsA('Humanoid') and obj.Parent ~= character then
                    -- Found NPC/Customer - interact logic here
                    local npcHrp = obj.Parent:FindFirstChild('HumanoidRootPart')
                    if npcHrp then
                        local distance = (npcHrp.Position - hrp.Position).Magnitude
                        if distance < 50 then
                            -- Move to NPC and interact
                            -- Add your specific Burger King job logic here
                        end
                    end
                elseif obj:IsA('ProximityPrompt') then
                    -- Check for order stations, grills, etc
                    local parentName = obj.Parent and obj.Parent.Name:lower() or ''
                    if parentName:find('order') or parentName:find('grill') or parentName:find('register') then
                        local distance = (obj.Parent.Position - hrp.Position).Magnitude
                        if distance < 20 then
                            fireproximityprompt(obj)
                        end
                    end
                end
            end
        end)
        
        if not success then
            warn('Burger King Error:', err)
        end
        
        task.wait(0.5)
    end
end

