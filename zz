local FlyEnabled = false
local v39 = v35:AddToggle('CFrameFly', {
    Text = 'Player Fly',
    Default = false,
    Callback = function(Value)
        FlyEnabled = Value
        local hum = LocalPlayer.Character:FindFirstChildOfClass('Humanoid')
        if hum then hum.PlatformStand = false end
        
        if Value then
            RunService.Heartbeat:Connect(function()
                if not FlyEnabled then 
                    local h = LocalPlayer.Character:FindFirstChildOfClass('Humanoid')
                    if h then h.PlatformStand = false end
                    return 
                end
                
                local hrp = LocalPlayer.Character:FindFirstChild('HumanoidRootPart')
                local h = LocalPlayer.Character:FindFirstChildOfClass('Humanoid')
                if not hrp or not h then return end
                
                h.PlatformStand = true
                local cam = Workspace.CurrentCamera
                local moveVec = Vector3.new(0, 0, 0)
                
                if UserInputService:IsKeyDown(Enum.KeyCode.W) then
                    moveVec = moveVec + cam.CFrame.LookVector
                end
                if UserInputService:IsKeyDown(Enum.KeyCode.S) then
                    moveVec = moveVec - cam.CFrame.LookVector
                end
                if UserInputService:IsKeyDown(Enum.KeyCode.A) then
                    moveVec = moveVec - cam.CFrame.RightVector
                end
                if UserInputService:IsKeyDown(Enum.KeyCode.D) then
                    moveVec = moveVec + cam.CFrame.RightVector
                end
                if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
                    moveVec = moveVec + Vector3.new(0, 1, 0)
                end
                if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
                    moveVec = moveVec - Vector3.new(0, 1, 0)
                end
                
                if moveVec.Magnitude > 0 then
                    hrp.CFrame = hrp.CFrame + (moveVec.Unit * 0.5)
                end
            end)
        end
    end
})

local CarFlyEnabled = false
local v40 = v35:AddToggle('CarFly', {
    Text = 'Car Fly',
    Default = false,
    Callback = function(Value)
        CarFlyEnabled = Value
        if Value then
            RunService.Heartbeat:Connect(function()
                if not CarFlyEnabled then return end
                local hum = LocalPlayer.Character:FindFirstChildOfClass('Humanoid')
                if not hum or not hum.SeatPart then return end
                
                local car = hum.SeatPart:FindFirstAncestorOfClass('Model')
                if not car then return end
                
                local cam = Workspace.CurrentCamera
                local moveVec = Vector3.new(0, 0, 0)
                
                if UserInputService:IsKeyDown(Enum.KeyCode.W) then
                    moveVec = moveVec + cam.CFrame.LookVector
                end
                if UserInputService:IsKeyDown(Enum.KeyCode.S) then
                    moveVec = moveVec - cam.CFrame.LookVector
                end
                if UserInputService:IsKeyDown(Enum.KeyCode.A) then
                    moveVec = moveVec - cam.CFrame.RightVector
                end
                if UserInputService:IsKeyDown(Enum.KeyCode.D) then
                    moveVec = moveVec + cam.CFrame.RightVector
                end
                if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
                    moveVec = moveVec + Vector3.new(0, 1, 0)
                end
                if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
                    moveVec = moveVec - Vector3.new(0, 1, 0)
                end
                
                if moveVec.Magnitude > 0 then
                    local primary = car:FindFirstChild('PrimaryPart') or car:FindFirstChild('HumanoidRootPart') or car:FindFirstChildOfClass('BasePart')
                    if primary then
                        primary.CFrame = primary.CFrame + (moveVec.Unit * 2)
                    end
                end
            end)
        end
    end
})

