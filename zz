-- Fonction pour trouver le job folder dynamiquement
local function GetJobFolder()
    local paths = {
        workspace:FindFirstChild('Map') and workspace.Map:FindFirstChild('Tiles') and workspace.Map.Tiles:FindFirstChild('GasStationTile') and workspace.Map.Tiles.GasStationTile:FindFirstChild('Quick11') and workspace.Map.Tiles.GasStationTile.Quick11:FindFirstChild('Interior') and workspace.Map.Tiles.GasStationTile.Quick11.Interior:FindFirstChild('ShelfStockingJob'),
        workspace:FindFirstChild('GasStationTile') and workspace.GasStationTile:FindFirstChild('Quick11') and workspace.GasStationTile.Quick11:FindFirstChild('Interior') and workspace.GasStationTile.Quick11.Interior:FindFirstChild('ShelfStockingJob'),
        workspace:FindFirstChild('ShelfStockingJob')
    }
    
    for _, path in ipairs(paths) do
        if path then return path end
    end
    
    -- Scanner tout workspace
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj.Name == 'ShelfStockingJob' then
            return obj
        end
    end
    
    return nil
end

-- Fonction pour trouver les emplacements vides sur les étagères
local function FindEmptySpots(shelvesFolder)
    local spots = {}
    
    for _, shelf in ipairs(shelvesFolder:GetChildren()) do
        -- Chercher les attachments (points de placement)
        for _, child in ipairs(shelf:GetDescendants()) do
            if child:IsA('Attachment') then
                -- Vérifier si déjà occupé
                local occupied = false
                for _, other in ipairs(shelf:GetDescendants()) do
                    if other:IsA('Model') and other.Name:lower():find('box') then
                        if (other:GetPivot().Position - child.WorldPosition).Magnitude < 2 then
                            occupied = true
                            break
                        end
                    end
                end
                
                if not occupied then
                    table.insert(spots, {
                        Position = child.WorldPosition,
                        Shelf = shelf,
                        Attachment = child
                    })
                end
            end
        end
    end
    
    return spots
end

-- Fonction pour trouver un proximity prompt près d'une position
local function FindPromptAtPosition(position, maxDist)
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA('ProximityPrompt') then
            local parent = obj.Parent
            if parent then
                local objPos = parent:IsA('BasePart') and parent.Position or (parent:IsA('Model') and parent:GetPivot().Position or nil)
                if objPos and (objPos - position).Magnitude < maxDist then
                    return obj
                end
            end
        end
    end
    return nil
end

local function GasStationFarm()
    while GasRunning do
        local success, err = pcall(function()
            -- Disable doors
            for _, val_2 in ipairs(workspace:GetDescendants()) do
                if val_2:IsA('BasePart') and val_2.Name:lower():find('door') then
                    val_2.CanQuery = false
                    val_2.CanCollide = false
                end
            end
            
            local character = LocalPlayer.Character
            if not character then return end
            
            local v10 = character:WaitForChild('Humanoid')
            local v11 = character:WaitForChild('HumanoidRootPart')
            
            -- Get job folder
            local jobFolder = GetJobFolder()
            if not jobFolder then
                warn('Job folder not found')
                return
            end
            
            local normalBox = jobFolder:FindFirstChild('NormalBox')
            local shelves = jobFolder:FindFirstChild('Shelves')
            
            if not normalBox or not shelves then
                warn('Box or shelves not found')
                return
            end
            
            local boxPrompt = normalBox:FindFirstChildOfClass('ProximityPrompt')
            
            -- ==========================================
            -- ÉTAPE 1: ALLER CHERCHER LA BOÎTE
            -- ==========================================
            
            local v12 = PathfindingService:CreatePath({
                AgentHeight = 5,
                AgentRadius = 2,
                AgentCanJump = true
            })
            
            local boxPos = Vector3.new(149.92399597168, 255.46714782715, 208.34700012207)
            v12:ComputeAsync(v11.Position, boxPos)
            
            local waypoints = v12:GetWaypoints()
            for _, waypoint in ipairs(waypoints) do
                if not GasRunning then return end
                v10:MoveTo(waypoint.Position)
                v10.MoveToFinished:Wait()
            end
            
            task.wait(0.3)
            
            -- Prendre la boîte
            if boxPrompt then
                fireproximityprompt(boxPrompt)
            end
            
            task.wait(0.8) -- Attendre que la boîte soit dans le backpack
            
            -- ==========================================
            -- ÉTAPE 2: TROUVER ET REMPLIR LES ÉTAGÈRES
            -- ==========================================
            
            -- Trouver les emplacements vides
            local emptySpots = FindEmptySpots(shelves)
            
            if #emptySpots == 0 then
                -- Pas d'emplacement vide, retourner la boîte ou attendre
                task.wait(2)
                return
            end
            
            -- Aller à chaque emplacement vide et placer
            for _, spot in ipairs(emptySpots) do
                if not GasRunning then return end
                
                -- Se déplacer vers l'emplacement
                local v21 = PathfindingService:CreatePath({
                    AgentHeight = 5,
                    AgentRadius = 2,
                    AgentCanJump = true
                })
                
                local targetPos = spot.Position + Vector3.new(0, 0, 2)
                v21:ComputeAsync(v11.Position, targetPos)
                
                local waypoints2 = v21:GetWaypoints()
                for _, waypoint in ipairs(waypoints2) do
                    if not GasRunning then return end
                    v10:MoveTo(waypoint.Position)
                    v10.MoveToFinished:Wait()
                end
                
                -- Orienter vers l'emplacement
                v11.CFrame = CFrame.new(v11.Position, spot.Position)
                task.wait(0.2)
                
                -- Chercher le prompt de placement
                local placePrompt = FindPromptAtPosition(spot.Position, 5)
                
                -- Chercher aussi dans l'étagère spécifique
                if not placePrompt then
                    for _, desc in ipairs(spot.Shelf:GetDescendants()) do
                        if desc:IsA('ProximityPrompt') then
                            placePrompt = desc
                            break
                        end
                    end
                end
                
                if placePrompt then
                    fireproximityprompt(placePrompt)
                    task.wait(0.5)
                end
                
                -- Vérifier si on a encore la boîte (si oui, continuer au prochain spot)
                local hasBox = false
                local backpack = LocalPlayer:FindFirstChild('Backpack')
                if backpack then
                    for _, tool in ipairs(backpack:GetChildren()) do
                        if tool.Name:lower():find('box') then
                            hasBox = true
                            break
                        end
                    end
                end
                for _, tool in ipairs(character:GetChildren()) do
                    if tool:IsA('Tool') and tool.Name:lower():find('box') then
                        hasBox = true
                        break
                    end
                end
                
                -- Si on n'a plus la boîte, elle a été placée
                if not hasBox then
                    break -- Sortir de la boucle des spots, retourner chercher une boîte
                end
                
                task.wait(0.3)
            end
        end)
        
        if not success then
            warn('Gas Station Error:', err)
        end
        
        task.wait(0.5) -- Attendre avant le prochain cycle
    end
end

