    Callback = function(Value)
        CarFlyEnabled = Value
        
        if Value then
            CarFlyConnection = RunService.Heartbeat:Connect(function()
                local humanoid = GetHumanoid()
                if not humanoid or not humanoid.SeatPart then return end
                
