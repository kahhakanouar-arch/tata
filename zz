-- FONCTIONS UTILES
-- ==========================================

local function GetCharacter()
    return LocalPlayer.Character
end

local function GetHumanoid()
    local char = GetCharacter()
    return char and char:FindFirstChildOfClass('Humanoid')
end

local function GetHRP()
    local char = GetCharacter()
    return char and char:FindFirstChild('HumanoidRootPart')
end

local function WaitForCharacter()
    local char = LocalPlayer.Character
    if not char then
        LocalPlayer.CharacterAdded:Wait()
        char = LocalPlayer.Character
    end
    return char
end

-- Pathfinding avancé avec visualisation
local function CreatePath(startPos, endPos)
    local path = PathfindingService:CreatePath({
        AgentHeight = 5,
        AgentRadius = 2,
        AgentCanJump = true,
        AgentJumpHeight = 10,
        AgentMaxSlope = 45,
        WaypointSpacing = 4
    })
    
    local success, errorMessage = pcall(function()
        path:ComputeAsync(startPos, endPos)
    end)
    
    if success and path.Status == Enum.PathStatus.Success then
        return path
    else
        warn('Pathfinding failed:', errorMessage or path.Status)
        return nil
    end
end

local function WalkPath(path, humanoid)
    if not path then return false end
    
    local waypoints = path:GetWaypoints()
    if #waypoints == 0 then return false end
    
    for i, waypoint in ipairs(waypoints) do
        if not GasStationEnabled and not BurgerKingEnabled then 
            humanoid:MoveTo(humanoid.RootPart.Position)
            return false 
        end
        
        humanoid:MoveTo(waypoint.Position)
        
        -- Attendre que le humanoid arrive ou que le chemin change
        local reached = false
        local connection
        connection = humanoid.MoveToFinished:Connect(function(arrived)
            reached = arrived
            connection:Disconnect()
        end)
        
        -- Timeout de sécurité
        local startTime = tick()
        while not reached and (tick() - startTime) < 3 do
            if not GasStationEnabled and not BurgerKingEnabled then
                connection:Disconnect()
                return false
            end
            RunService.Heartbeat:Wait()
        end
        
        connection:Disconnect()
        
        -- Si waypoint nécessite un saut
        if waypoint.Action == Enum.PathWaypointAction.Jump then
            humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
            task.wait(0.3)
        end
    end
    
    return true
end

local function MoveToPosition(targetPos, humanoid)
    if not humanoid or not humanoid.RootPart then return false end
    
    local startPos = humanoid.RootPart.Position
    local path = CreatePath(startPos, targetPos)
    
    if path then
        return WalkPath(path, humanoid)
    else
        -- Fallback: déplacement direct
        humanoid:MoveTo(targetPos)
        humanoid.MoveToFinished:Wait()
        return true
    end
end

-- ==========================================
-- GAS STATION AUTOFARM - CORRIGÉ
-- ==========================================

local GasGroup = AutofarmTab:AddLeftGroupbox('⛽ Gas Station', 'fuel')

local GasConnections = {}

local function ClearGasConnections()
    for _, conn in ipairs(GasConnections) do
        if conn then conn:Disconnect() end
    end
    GasConnections = {}
end

local function GetGasStationObjects()
    local map = Workspace:FindFirstChild('Map')
    if not map then return nil end
    
    local tiles = map:FindFirstChild('Tiles')
    if not tiles then return nil end
    
    local gasTile = tiles:FindFirstChild('GasStationTile')
    if not gasTile then return nil end
    
    local quick11 = gasTile:FindFirstChild('Quick11')
    if not quick11 then return nil end
    
    local interior = quick11:FindFirstChild('Interior')
    if not interior then return nil end
    
    local jobFolder = interior:FindFirstChild('ShelfStockingJob')
    if not jobFolder then return nil end
    
    return jobFolder
end

local function DisableDoors()
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA('BasePart') and obj.Name:lower():find('door') then
            obj.CanCollide = false
            obj.CanQuery = false
        end
    end
end

local function GasStationLoop()
    while GasStationEnabled do
        local success, err = pcall(function()
            -- Attendre le personnage
            local char = WaitForCharacter()
            local humanoid = char:WaitForChild('Humanoid')
            local hrp = char:WaitForChild('HumanoidRootPart')
            
            task.wait(0.5)
            
            -- Désactiver les portes
            DisableDoors()
            
            -- Récupérer les objets
            local jobFolder = GetGasStationObjects()
            if not jobFolder then
                ObsidianLib:Notify({
                    Title = 'Gas Station',
                    Content = 'Job folder not found! Take the job first.',
                    Duration = 3
                })
                task.wait(2)
                return
            end
            
            local box = jobFolder:FindFirstChild('NormalBox')
            local shelves = jobFolder:FindFirstChild('Shelves')
            
            if not box or not shelves then
                ObsidianLib:Notify({
                    Title = 'Gas Station',
                    Content = 'Box or shelves not found!',
                    Duration = 3
                })
                task.wait(2)
                return
            end
            
            -- Position de la boîte (ajustée selon la map)
            local boxPos = box:GetPivot().Position
            
            -- 1. Aller chercher la boîte
            ObsidianLib:Notify({
                Title = 'Gas Station',
                Content = 'Moving to box...',
                Duration = 2
            })
            
            local moved = MoveToPosition(boxPos + Vector3.new(0, 0, 3), humanoid)
            if not moved then return end
            
            task.wait(0.3)
            
            -- Interagir avec la boîte
            local prompt = box:FindFirstChildOfClass('ProximityPrompt')
            if prompt then
                fireproximityprompt(prompt)
                ObsidianLib:Notify({
                    Title = 'Gas Station',
                    Content = 'Box grabbed!',
                    Duration = 1
                })
            end
            
            task.wait(0.8)
            
            -- 2. Aller aux étagères
            local shelfList = shelves:GetChildren()
            if #shelfList == 0 then
                ObsidianLib:Notify({
                    Title = 'Gas Station',
                    Content = 'No shelves found!',
                    Duration = 2
                })
                return
            end
            
            -- Trouver l'étagère la plus proche avec un slot vide
            for _, shelf in ipairs(shelfList) do
                if not GasStationEnabled then break end
                
                local shelfPos = shelf:GetPivot().Position
                local distance = (shelfPos - hrp.Position).Magnitude
                
                if distance < 100 then
                    ObsidianLib:Notify({
                        Title = 'Gas Station',
                        Content = 'Stocking shelf...',
                        Duration = 1
                    })
                    
                    -- Se déplacer devant l'étagère
                    local targetPos = shelfPos + Vector3.new(0, 0, 4)
                    moved = MoveToPosition(targetPos, humanoid)
                    
                    if moved then
                        task.wait(0.5)
                        
                        -- Chercher les prompts sur l'étagère
                        for _, child in ipairs(shelf:GetDescendants()) do
                            if child:IsA('ProximityPrompt') then
                                fireproximityprompt(child)
                                task.wait(0.3)
                            end
                        end
                    end
                    
                    task.wait(0.5)
                end
            end
        end)
        
        if not success then
            warn('Gas Station Error:', err)
            ObsidianLib:Notify({
                Title = 'Error',
                Content = tostring(err):sub(1, 50),
                Duration = 3
            })
        end
        
        task.wait(1)
    end
end

GasGroup:AddLabel('⚠️ PRENDS LE JOB AVANT DE START!')

GasGroup:AddToggle('GasStationToggle', {
    Text = 'Enable Gas Station Autofarm',
