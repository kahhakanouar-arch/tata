-- Variables globales pour le toggle
local GasFarmRunning = false
local GasThread = nil

-- Fonction corrigée du Gas Station
local function GasStationFarm()
    while GasFarmRunning do
        local success, err = pcall(function()
            -- Disable doors (corrigé)
            for _, val_2 in ipairs(Workspace:GetDescendants()) do
                local v3 = val_2:IsA('BasePart')
                local v4 = val_2.Name:lower()
                local v5 = v4:find('door')
                if v3 and v5 then
                    val_2.CanQuery = false
                    val_2.CanCollide = false
                end
            end
            
            -- Get character parts (corrigé)
            local character = LocalPlayer.Character
            if not character then return end
            
            local v10 = character:WaitForChild('Humanoid')
            local v11 = character:WaitForChild('HumanoidRootPart')
            
            -- Get job objects (corrigé avec chemins dynamiques)
            local gasTile = Workspace:FindFirstChild('Map') and 
                           Workspace.Map:FindFirstChild('Tiles') and 
                           Workspace.Map.Tiles:FindFirstChild('GasStationTile')
            
            if not gasTile then
                -- Fallback: chercher par nom
                for _, obj in ipairs(Workspace:GetDescendants()) do
                    if obj.Name:lower():find('gas') or obj.Name:lower():find('quick') then
                        gasTile = obj
                        break
                    end
                end
            end
            
            if not gasTile then return end
            
            local quick11 = gasTile:FindFirstChild('Quick11') or gasTile
            local interior = quick11:FindFirstChild('Interior')
            if not interior then return end
            
            local jobFolder = interior:FindFirstChild('ShelfStockingJob')
            if not jobFolder then return end
            
            local v8 = jobFolder:WaitForChild('NormalBox'):WaitForChild('ProximityPrompt')
            local v9 = jobFolder:WaitForChild('Shelves'):GetChildren()
            
            -- Create path (corrigé)
            local v12 = PathfindingService:CreatePath({
                AgentHeight = 5,
                AgentRadius = 2,
                AgentCanJump = true
            })
            
            -- Path to box position (corrigé: ComputeAsync et MoveTo)
            local boxPos = Vector3.new(149.92399597168, 255.46714782715, 208.34700012207)
            v12:ComputeAsync(v11.Position, boxPos)
            
            -- Walk path (corrigé)
            local waypoints = v12:GetWaypoints()
            for _, waypoint in ipairs(waypoints) do
                if not GasFarmRunning then break end
                v10:MoveTo(waypoint.Position)
                v10.MoveToFinished:Wait()
            end
            
            task.wait(0.3)
            fireproximityprompt(v8)
            task.wait(0.5)
            
            -- Path to shelves (corrigé)
            local shelfPos = Vector3.new(130.80842590332, 255.46714782715, 203.29504394531)
            local v21 = PathfindingService:CreatePath({
                AgentHeight = 5,
                AgentRadius = 2,
                AgentCanJump = true
            })
            
            v21:ComputeAsync(v11.Position, shelfPos)
            local waypoints2 = v21:GetWaypoints()
            for _, waypoint in ipairs(waypoints2) do
                if not GasFarmRunning then break end
                v10:MoveTo(waypoint.Position)
                v10.MoveToFinished:Wait()
            end
            
            task.wait(0.5)
            
            -- Interact with shelves (corrigé)
            for _, val_26 in ipairs(v9) do
                if not GasFarmRunning then break end
                local v27 = val_26:GetChildren()
                for _, val_28 in ipairs(v27) do
                    if val_28:IsA('Attachment') then
                        local v30 = (val_28.WorldPosition - v11.Position).Magnitude
                        if v30 < 10 then
                            -- Interaction avec l'étagère
                            local shelfPrompt = val_26:FindFirstChildOfClass('ProximityPrompt')
                            if shelfPrompt then
                                fireproximityprompt(shelfPrompt)
                                task.wait(0.3)
                            end
                        end
                    end
                end
            end
        end)
        
        if not success then
            warn('Gas Station Error:', err)
        end
        task.wait(1)
    end
end

