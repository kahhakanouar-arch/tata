-- Variables
local BurgerFarmRunning = false

-- Fonction corrigée Burger King
local function BurgerKingFarm()
    while BurgerFarmRunning do
        local success, err = pcall(function()
            local v1 = LocalPlayer.Character:WaitForChild('Humanoid')
            local v2 = LocalPlayer.Character:WaitForChild('HumanoidRootPart')
            
            -- Chercher BurgerPlaceTile (corrigé)
            local burgerTile = Workspace:FindFirstChild('Map') and 
                              Workspace.Map:FindFirstChild('Tiles') and 
                              Workspace.Map.Tiles:FindFirstChild('BurgerPlaceTile')
            
            if not burgerTile then
                -- Fallback
                for _, obj in ipairs(Workspace:GetDescendants()) do
                    if obj.Name:lower():find('burger') then
                        burgerTile = obj
                        break
                    end
                end
            end
            
            if not burgerTile then return end
            
            local v3 = burgerTile:GetDescendants()
            
            for _, val_4 in ipairs(v3) do
                if not BurgerFarmRunning then break end
                
                -- Détecter les humanoids (clients ou objets de job)
                local v5 = val_4:IsA('Humanoid')
                if v5 and val_4.Parent ~= LocalPlayer.Character then
                    local npcHRP = val_4.Parent:FindFirstChild('HumanoidRootPart')
                    if npcHRP then
                        local distance = (npcHRP.Position - v2.Position).Magnitude
                        if distance < 50 then
                            -- Aller vers le NPC/client
                            local path = PathfindingService:CreatePath({
                                AgentHeight = 5,
                                AgentRadius = 2,
                                AgentCanJump = true
                            })
                            
                            path:ComputeAsync(v2.Position, npcHRP.Position)
                            local waypoints = path:GetWaypoints()
                            
                            for _, wp in ipairs(waypoints) do
                                if not BurgerFarmRunning then break end
                                v1:MoveTo(wp.Position)
                                v1.MoveToFinished:Wait()
                            end
                            
                            -- Interagir avec les prompts proches
                            for _, prompt in ipairs(val_4.Parent:GetDescendants()) do
                                if prompt:IsA('ProximityPrompt') then
                                    fireproximityprompt(prompt)
                                    task.wait(0.3)
                                end
                            end
                        end
                    end
                end
                
                -- Détecter les objets de job (mop, spills, etc)
                local name = val_4.Name:lower()
                if name:find('mop') or name:find('spill') or name:find('puddle') or 
                   name:find('grill') or name:find('fryer') or name:find('register') then
                    
                    if val_4:IsA('BasePart') or val_4:IsA('MeshPart') then
                        local distance = (val_4.Position - v2.Position).Magnitude
                        if distance < 100 then
                            local path = PathfindingService:CreatePath({
                                AgentHeight = 5,
                                AgentRadius = 2,
                                AgentCanJump = true
                            })
                            
                            path:ComputeAsync(v2.Position, val_4.Position)
                            local waypoints = path:GetWaypoints()
                            
                            for _, wp in ipairs(waypoints) do
                                if not BurgerFarmRunning then break end
                                v1:MoveTo(wp.Position)
                                v1.MoveToFinished:Wait()
                            end
                            
                            task.wait(0.3)
                            
                            -- Chercher et interagir avec les prompts
                            for _, prompt in ipairs(val_4:GetDescendants()) do
                                if prompt:IsA('ProximityPrompt') then
                                    fireproximityprompt(prompt)
                                    task.wait(0.5)
                                end
                            end
                        end
                    end
                end
            end
        end)
        
        if not success then
            warn('Burger King Error:', err)
        end
        task.wait(1)
    end
end

