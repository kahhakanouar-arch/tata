        end
    end
})

-- ==========================================
-- BURGER KING AUTOFARM - CORRIGÉ
-- ==========================================

local BurgerGroup = AutofarmTab:AddRightGroupbox('🍔 Burger King', 'utensils')

local BurgerConnections = {}

local function ClearBurgerConnections()
    for _, conn in ipairs(BurgerConnections) do
        if conn then conn:Disconnect() end
    end
    BurgerConnections = {}
end

local function GetBurgerKingObjects()
    local map = Workspace:FindFirstChild('Map')
    if not map then return nil end
    
    local tiles = map:FindFirstChild('Tiles')
    if not tiles then return nil end
    
    return tiles:FindFirstChild('BurgerPlaceTile')
end

local function FindJobPrompts(tile)
    local prompts = {}
    
    for _, obj in ipairs(tile:GetDescendants()) do
        if obj:IsA('ProximityPrompt') then
            local parentName = obj.Parent and obj.Parent.Name:lower() or ''
            local name = obj.Name:lower()
            
            -- Détecter les stations de travail
            if parentName:find('register') or 
               parentName:find('grill') or 
               parentName:find('fryer') or
               parentName:find('counter') or
               parentName:find('order') or
               name:find('work') or
               name:find('interact') then
                
                table.insert(prompts, {
                    Prompt = obj,
                    Position = obj.Parent:GetPivot().Position,
                    Type = parentName
                })
            end
        end
    end
    
    return prompts
end

local function FindCustomers(tile)
    local customers = {}
    
    for _, obj in ipairs(tile:GetDescendants()) do
        if obj:IsA('Humanoid') and obj.Parent then
            local isPlayer = Players:GetPlayerFromCharacter(obj.Parent)
            if not isPlayer then
                -- C'est un NPC
                local hrp = obj.Parent:FindFirstChild('HumanoidRootPart')
                if hrp then
                    table.insert(customers, {
                        Humanoid = obj,
                        HRP = hrp,
                        Position = hrp.Position
                    })
                end
            end
        end
    end
    
    return customers
end

local function BurgerKingLoop()
    while BurgerKingEnabled do
        local success, err = pcall(function()
            local char = WaitForCharacter()
            local humanoid = char:WaitForChild('Humanoid')
            local hrp = char:WaitForChild('HumanoidRootPart')
            
            task.wait(0.5)
            
            local tile = GetBurgerKingObjects()
            if not tile then
                ObsidianLib:Notify({
                    Title = 'Burger King',
                    Content = 'BurgerPlaceTile not found! Take the job first.',
                    Duration = 3
                })
                task.wait(2)
                return
            end
            
            -- Chercher les stations de travail
            local prompts = FindJobPrompts(tile)
            
            if #prompts > 0 then
                -- Aller à chaque station et interagir
                for _, station in ipairs(prompts) do
                    if not BurgerKingEnabled then break end
                    
                    local distance = (station.Position - hrp.Position).Magnitude
                    
                    if distance > 5 then
                        ObsidianLib:Notify({
                            Title = 'Burger King',
                            Content = 'Moving to ' .. station.Type .. '...',
                            Duration = 1
                        })
                        
                        local targetPos = station.Position + Vector3.new(0, 0, 3)
                        local moved = MoveToPosition(targetPos, humanoid)
                        
                        if moved then
                            task.wait(0.3)
                        end
                    end
                    
                    -- Interagir
                    fireproximityprompt(station.Prompt)
                    task.wait(0.5)
                end
            end
            
            -- Chercher les clients
            local customers = FindCustomers(tile)
            
            for _, customer in ipairs(customers) do
                if not BurgerKingEnabled then break end
                
                local distance = (customer.Position - hrp.Position).Magnitude
                
                if distance < 50 and distance > 5 then
                    ObsidianLib:Notify({
                        Title = 'Burger King',
                        Content = 'Serving customer...',
                        Duration = 1
                    })
                    
                    local targetPos = customer.Position + Vector3.new(2, 0, 2)
                    MoveToPosition(targetPos, humanoid)
                    task.wait(0.5)
                end
            end
        end)
        
        if not success then
            warn('Burger King Error:', err)
        end
        
        task.wait(1)
    end
end

BurgerGroup:AddLabel('⚠️ PRENDS LE JOB AVANT DE START!')

BurgerGroup:AddToggle('BurgerKingToggle', {
    Text = 'Enable Burger King Autofarm',
