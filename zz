local GasStationAutofarm = false
GasStationGroup:AddToggle("AutofarmToggle", {
    Text = "Autofarm Gas Station",
    Default = false,
    Callback = function(Value)
        GasStationAutofarm = Value
        if Value then
            task.spawn(function()
                while GasStationAutofarm do
                    local success, err = pcall(function()
                        for _, obj in ipairs(Workspace:GetDescendants()) do
                            if obj:IsA("BasePart") and obj.Name:lower():find("door") then
                                obj.CanQuery = false
                            end
                        end
                        
                        local jobFolder = Workspace:FindFirstChild("Map") 
                            and Workspace.Map:FindFirstChild("Tiles") 
                            and Workspace.Map.Tiles:FindFirstChild("GasStationTile")
                        
                        if not jobFolder then return end
                        
                        local quick11 = jobFolder:FindFirstChild("Quick11")
                        if not quick11 then return end
                        
                        local interior = quick11:FindFirstChild("Interior")
                        if not interior then return end
                        
                        local job = interior:FindFirstChild("ShelfStockingJob")
                        if not job then return end
                        
                        local prompt = job:FindFirstChild("NormalBox") 
                            and job.NormalBox:FindFirstChild("ProximityPrompt")
                        
                        local shelves = job:FindFirstChild("Shelves")
                        if not shelves then return end
                        
                        local humanoid = GetHumanoid()
                        local rootPart = GetRootPart()
                        if not humanoid or not rootPart then return end
                        
                        local path = PathfindingService:CreatePath({
                            AgentHeight = 5,
                            AgentRadius = 2,
                            AgentCanJump = true
                        })
                        
                        path:ComputeAsync(rootPart.Position, Vector3.new(149.924, 255.467, 208.347))
                        path:MoveTo(humanoid)
                        humanoid.MoveToFinished:Wait()
                        task.wait(0.3)
                        
                        if prompt then
                            fireproximityprompt(prompt)
                        end
                        task.wait(0.5)
                        
                        local path2 = PathfindingService:CreatePath({
                            AgentHeight = 5,
                            AgentRadius = 2,
                            AgentCanJump = true
                        })
                        
                        local newRoot = GetRootPart()
                        if newRoot then
                            path2:ComputeAsync(newRoot.Position, Vector3.new(130.808, 255.467, 203.295))
                            path2:MoveTo(humanoid)
                            humanoid.MoveToFinished:Wait()
                        end
                        task.wait(0.5)
                    end)
                    
                    if not success then
                        warn("Gas Station Autofarm Error:", err)
                    end
                    
                    task.wait(1)
                end
            end)
        end
    end
})

