local v33 = v30:AddLabel('Take the Job before start')

local BurgerRunning = false

local function GetBurgerFolder()
    local paths = {
        workspace:FindFirstChild('Map') and workspace.Map:FindFirstChild('Tiles') and workspace.Map.Tiles:FindFirstChild('BurgerPlaceTile'),
        workspace:FindFirstChild('BurgerPlaceTile'),
        workspace:FindFirstChild('BurgerPlace')
    }
    
    for _, path in ipairs(paths) do
        if path then return path end
    end
    
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj.Name:lower():find('burger') and (obj:IsA('Model') or obj:IsA('Folder')) then
            return obj
        end
    end
    
    return nil
end

local function BurgerKingFarm()
    while BurgerRunning do
        local success, err = pcall(function()
            local v1 = LocalPlayer.Character:WaitForChild('Humanoid')
            local v2 = LocalPlayer.Character:WaitForChild('HumanoidRootPart')
            
            local burgerFolder = GetBurgerFolder()
            if not burgerFolder then return end
            
            local descendants = burgerFolder:GetDescendants()
            
            for _, val_4 in ipairs(descendants) do
                if not BurgerRunning then return end
                
                -- Détecter les humanoids (clients)
                if val_4:IsA('Humanoid') and val_4.Parent ~= LocalPlayer.Character then
                    local npcHRP = val_4.Parent:FindFirstChild('HumanoidRootPart')
                    if npcHRP then
                        local distance = (npcHRP.Position - v2.Position).Magnitude
                        
                        if distance < 50 then
                            local path = PathfindingService:CreatePath({
                                AgentHeight = 5,
                                AgentRadius = 2,
                                AgentCanJump = true
                            })
                            
                            path:ComputeAsync(v2.Position, npcHRP.Position)
                            local waypoints = path:GetWaypoints()
                            
                            for _, wp in ipairs(waypoints) do
                                if not BurgerRunning then return end
                                v1:MoveTo(wp.Position)
                                v1.MoveToFinished:Wait()
                            end
                            
                            -- Interagir avec tous les prompts du NPC
                            for _, prompt in ipairs(val_4.Parent:GetDescendants()) do
                                if prompt:IsA('ProximityPrompt') then
                                    fireproximityprompt(prompt)
                                    task.wait(0.3)
                                end
                            end
                        end
                    end
                end
                
                -- Détecter les objets de job
                local name = val_4.Name:lower()
                if name:find('mop') or name:find('spill') or name:find('puddle') or 
                   name:find('grill') or name:find('fryer') or name:find('register') then
                    
                    if val_4:IsA('BasePart') or val_4:IsA('MeshPart') then
                        local distance = (val_4.Position - v2.Position).Magnitude
                        
                        if distance < 100 and distance > 5 then
                            local path = PathfindingService:CreatePath({
                                AgentHeight = 5,
                                AgentRadius = 2,
                                AgentCanJump = true
                            })
                            
                            path:ComputeAsync(v2.Position, val_4.Position)
                            local waypoints = path:GetWaypoints()
                            
                            for _, wp in ipairs(waypoints) do
                                if not BurgerRunning then return end
                                v1:MoveTo(wp.Position)
                                v1.MoveToFinished:Wait()
                            end
                            
                            task.wait(0.3)
                            
                            -- Interagir avec tous les prompts
                            for _, prompt in ipairs(val_4:GetDescendants()) do
                                if prompt:IsA('ProximityPrompt') then
                                    fireproximityprompt(prompt)
                                    task.wait(0.5)
                                end
                            end
                        end
                    end
                end
            end
        end)
        
        if not success then
            warn('Burger King Error:', err)
        end
        
        task.wait(1)
    end
end

