local function CreateESPObject(player)
    if player == LocalPlayer then return end
    
    local espData = {
        Player = player,
        Box = Drawing.new("Square"),
        BoxOutline = Drawing.new("Square"),
        HealthBar = Drawing.new("Line"),
        HealthBarOutline = Drawing.new("Line"),
        Name = Drawing.new("Text"),
        Distance = Drawing.new("Text"),
        Weapon = Drawing.new("Text"),
        Backpack = Drawing.new("Text"),
        SkeletonLines = {}
    }
    
    espData.Box.Visible = false
    espData.Box.ZIndex = 5
    espData.Box.Thickness = 1.5
    espData.Box.Filled = false
    
    espData.BoxOutline.Visible = false
    espData.BoxOutline.ZIndex = 4
    espData.BoxOutline.Thickness = 4
    espData.BoxOutline.Color = Color3.fromRGB(0, 0, 0)
    espData.BoxOutline.Filled = false
    
    espData.HealthBar.Visible = false
    espData.HealthBar.ZIndex = 5
    espData.HealthBar.Thickness = 3
    
    espData.HealthBarOutline.Visible = false
    espData.HealthBarOutline.ZIndex = 4
    espData.HealthBarOutline.Thickness = 5
    espData.HealthBarOutline.Color = Color3.fromRGB(0, 0, 0)
    
    espData.Name.Visible = false
    espData.Name.ZIndex = 5
    espData.Name.Center = true
    espData.Name.Outline = true
    espData.Name.Size = 13
    
    espData.Distance.Visible = false
    espData.Distance.ZIndex = 5
    espData.Distance.Center = true
    espData.Distance.Outline = true
    espData.Distance.Size = 12
    
    espData.Weapon.Visible = false
    espData.Weapon.ZIndex = 5
    espData.Weapon.Center = true
    espData.Weapon.Outline = true
    espData.Weapon.Size = 12
    
    espData.Backpack.Visible = false
    espData.Backpack.ZIndex = 5
    espData.Backpack.Center = true
    espData.Backpack.Outline = true
    espData.Backpack.Size = 11
    
    for i = 1, 14 do
        local line = Drawing.new("Line")
        line.Visible = false
        line.ZIndex = 5
        line.Thickness = 1.5
        table.insert(espData.SkeletonLines, line)
    end
    
    ESPObjects[player] = espData
    return espData
end

local function RemoveESPObject(player)
    local espData = ESPObjects[player]
    if not espData then return end
    
    pcall(function()
        espData.Box:Remove()
        espData.BoxOutline:Remove()
        espData.HealthBar:Remove()
        espData.HealthBarOutline:Remove()
        espData.Name:Remove()
        espData.Distance:Remove()
        espData.Weapon:Remove()
        espData.Backpack:Remove()
        
        for _, line in ipairs(espData.SkeletonLines) do
            line:Remove()
        end
    end)
    
    ESPObjects[player] = nil
end

for _, player in ipairs(Players:GetPlayers()) do
    CreateESPObject(player)
end

Players.PlayerAdded:Connect(CreateESPObject)
Players.PlayerRemoving:Connect(RemoveESPObject)

RunService.RenderStepped:Connect(function()
    if not ESPEnabled then
        for _, espData in pairs(ESPObjects) do
            pcall(function()
                espData.Box.Visible = false
                espData.BoxOutline.Visible = false
                espData.HealthBar.Visible = false
                espData.HealthBarOutline.Visible = false
                espData.Name.Visible = false
                espData.Distance.Visible = false
                espData.Weapon.Visible = false
                espData.Backpack.Visible = false
                for _, line in ipairs(espData.SkeletonLines) do
                    line.Visible = false
                end
            end)
        end
        return
    end
    
    local camera = Workspace.CurrentCamera
    local localRoot = GetRootPart()
    
    for player, espData in pairs(ESPObjects) do
        local success, err = pcall(function()
            local character = player.Character
            local humanoid = character and character:FindFirstChildOfClass("Humanoid")
            local rootPart = character and character:FindFirstChild("HumanoidRootPart")
            
            if not character or not humanoid or not rootPart then
                espData.Box.Visible = false
                espData.BoxOutline.Visible = false
                espData.HealthBar.Visible = false
                espData.HealthBarOutline.Visible = false
                espData.Name.Visible = false
                espData.Distance.Visible = false
                return
            end
            
            local distance = localRoot and (rootPart.Position - localRoot.Position).Magnitude or 0
            if distance > ESPMaxDistance then
                espData.Box.Visible = false
                espData.BoxOutline.Visible = false
                espData.HealthBar.Visible = false
                espData.HealthBarOutline.Visible = false
                espData.Name.Visible = false
                espData.Distance.Visible = false
                return
            end
            
            local minX, minY, maxX, maxY = math.huge, math.huge, -math.huge, -math.huge
            local onScreen = false
            
            for _, part in ipairs(character:GetDescendants()) do
                if part:IsA("BasePart") then
                    local pos, visible = camera:WorldToViewportPoint(part.Position)
                    if visible then
                        onScreen = true
                        minX = math.min(minX, pos.X)
                        minY = math.min(minY, pos.Y)
                        maxX = math.max(maxX, pos.X)
                        maxY = math.max(maxY, pos.Y)
                    end
                end
            end
            
            if not onScreen then
                espData.Box.Visible = false
                espData.BoxOutline.Visible = false
                espData.HealthBar.Visible = false
                espData.HealthBarOutline.Visible = false
                espData.Name.Visible = false
                espData.Distance.Visible = false
                return
            end
            
            local boxWidth = maxX - minX
            local boxHeight = maxY - minY
            local boxColor = (ESPFriendCheck and LocalPlayer:IsFriendsWith(player.UserId)) and ESPFriendColor or ESPBoxColor
            
            if ESPFullBox then
                espData.Box.Visible = true
                espData.BoxOutline.Visible = true
                espData.Box.Size = Vector2.new(boxWidth, boxHeight)
                espData.Box.Position = Vector2.new(minX, minY)
                espData.Box.Color = boxColor
                espData.BoxOutline.Size = Vector2.new(boxWidth, boxHeight)
                espData.BoxOutline.Position = Vector2.new(minX, minY)
            else
                espData.Box.Visible = false
                espData.BoxOutline.Visible = false
            end
            
            if ESPHealthBar then
                local healthPercent = humanoid.Health / humanoid.MaxHealth
                local barHeight = boxHeight * healthPercent
                
                espData.HealthBar.Visible = true
                espData.HealthBarOutline.Visible = true
                espData.HealthBar.From = Vector2.new(minX - 6, minY + boxHeight)
                espData.HealthBar.To = Vector2.new(minX - 6, minY + boxHeight - barHeight)
                espData.HealthBar.Color = ESPHealthColor
                espData.HealthBarOutline.From = Vector2.new(minX - 6, minY + boxHeight)
                espData.HealthBarOutline.To = Vector2.new(minX - 6, minY)
            else
                espData.HealthBar.Visible = false
                espData.HealthBarOutline.Visible = false
            end
            
            if ESPName then
                espData.Name.Visible = true
                espData.Name.Position = Vector2.new(minX + boxWidth / 2, minY - 15)
                espData.Name.Text = player.Name
                espData.Name.Color = ESPTextColor
            else
                espData.Name.Visible = false
            end
            
            if ESPDistance then
                espData.Distance.Visible = true
                espData.Distance.Position = Vector2.new(minX + boxWidth / 2, maxY + 2)
                espData.Distance.Text = math.floor(distance) .. " studs"
                espData.Distance.Color = ESPTextColor
            else
                espData.Distance.Visible = false
            end
        end)
    end
end)

